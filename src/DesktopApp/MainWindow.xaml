<Window
    x:Class="DesktopApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vitals Monitor"
    Height="520"
    Width="840">
    <DockPanel
        Margin="10">
        <!-- Top controls -->
        <StackPanel
            DockPanel.Dock="Top"
            Orientation="Horizontal"
            Margin="0,0,0,10">
            <Button
                Width="100"
                Height="30"
                Margin="0,0,10,0"
                Content="Refresh"
                Command="{Binding RefreshCommand}" />
            <TextBlock
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="{Binding Status}" />
        </StackPanel>
        <!-- Data grid for measurements -->
        <DataGrid
            AutoGenerateColumns="True"
            IsReadOnly="True"
            ItemsSource="{Binding Measurements}" />
    </DockPanel>
</Window>
