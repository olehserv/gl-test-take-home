<Window
    x:Class="DesktopApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vitals Monitor"
    Height="520"
    Width="840">
    <DockPanel
        Margin="10">
        <!-- Top controls -->
        <StackPanel
            DockPanel.Dock="Top"
            Orientation="Horizontal"
            Margin="0,0,0,10">
            <Button
                Name="btnRefresh"
                Width="100"
                Height="30"
                Margin="0,0,10,0"
                Content="Refresh"
                Click="Button_Click" />
            <TextBlock
                Name="txtStatus"
                VerticalAlignment="Center"
                FontWeight="Bold" />
        </StackPanel>
        <!-- Data grid for measurements -->
        <DataGrid
            Name="dataGrid"
            AutoGenerateColumns="True"
            IsReadOnly="True"
            DockPanel.Dock="Bottom"
            Height="400" />
    </DockPanel>
</Window>